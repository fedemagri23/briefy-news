# Google AI Studio → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# SMTP — ejemplo con Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com

# Gmail: Google Account → Seguridad → Verificación en 2 pasos → Contraseñas de aplicaciones
SMTP_PASS=

SMTP_FROM="News Digest <tu@gmail.com>"

# Separados por coma, sin espacios
SUBSCRIBERS=tu@gmail.com

NEWS_TOPICS=tecnología,ciencia,economía global
NEWS_COUNT_ARGENTINA=5
NEWS_COUNT_INTERNATIONAL=5