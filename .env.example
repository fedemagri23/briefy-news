GOOGLE_API_KEY=tu-api-key

# Configuración del servidor
PORT=3000

# Configuración de email (Gmail)
EMAIL_USER=tu-email@gmail.com
EMAIL_PASSWORD=tu-app-password-de-gmail

# Lista de destinatarios del newsletter (separados por comas)
# Ejemplo: EMAIL_RECIPIENTS=email1@example.com,email2@example.com,email3@example.com
EMAIL_RECIPIENTS=email1@example.com,email2@example.com

# Prefijo para el asunto del email
EMAIL_SUBJECT_PREFIX=📰 Noticias Diarias

# Configuración del scheduler (cron job)
# Formato: minuto hora día mes día-semana
# Ejemplos:
#   "00 07 * * *" = todos los días a las 07:00
#   "30 08 * * *" = todos los días a las 08:30
#   "00 09 * * 1-5" = lunes a viernes a las 09:00
#   "00 12 * * 0" = todos los domingos a las 12:00
SCHEDULER_CRON=00 07 * * *

# Zona horaria para el scheduler
# Lista completa: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Ejemplos:
#   America/Argentina/Buenos_Aires
#   America/Mexico_City
#   Europe/Madrid
#   America/New_York
SCHEDULER_TIMEZONE=America/Argentina/Buenos_Aires

# Habilitar/deshabilitar el scheduler automático
# true = habilitado (por defecto), false = deshabilitado
SCHEDULER_ENABLED=true

# Modelos de Gemini AI a usar (separados por comas)
# Se intentarán en orden, si uno falla se usará el siguiente
# Ejemplo: GEMINI_MODELS=gemini-3-flash-preview,gemini-2.5-flash,gemini-1.5-pro
GEMINI_MODELS=gemini-3-flash-preview,gemini-2.5-flash

# Configuración de cantidad de noticias
# Cantidad de noticias argentinas a incluir en el newsletter
NEWS_COUNT_ARGENTINA=5

# Cantidad de noticias internacionales a incluir en el newsletter
NEWS_COUNT_INTERNATIONAL=5

# Configuración de categorías de noticias
# Lista de categorías separadas por comas que la IA puede usar
# Ejemplo: NEWS_CATEGORIES=Político,Económico,Social,General,Tecnología
NEWS_CATEGORIES=Político,Económico,Social,General

# Mapeo de categorías a archivos de imagen
# Formato: "Categoría:archivo.png,Categoría2:archivo2.png"
# Los archivos deben estar en src/assets/img/
# Ejemplo: NEWS_CATEGORY_IMAGE_MAP=Político:polÍtica.png,Económico:economía.png,Social:social.png,General:social.png
NEWS_CATEGORY_IMAGE_MAP=Político:polÍtica.png,Económico:economía.png,Social:social.png,General:social.png

# Mapeo de categorías a colores (hex)
# Formato: "Categoría:#colorhex,Categoría2:#colorhex2"
# Ejemplo: NEWS_CATEGORY_COLOR_MAP=Político:#e53935,Económico:#1e88e5,Social:#43a047,General:#6c757d
NEWS_CATEGORY_COLOR_MAP=Político:#e53935,Económico:#1e88e5,Social:#43a047,General:#6c757d
